+      ((mod/make-adder 5) 7)
+      (module-smoke/square 3)])
+
+(out [mod/module-counter
+      (mod/next)
+      (mod/next)])
+
+(set mod/module-counter 100)
+
+(out [mod/module-counter
+      (mod/next)])
+
+(out mod/exported-vector)
+(push mod/exported-vector 3)
+(out mod/exported-vector)
+
+
 (nl)
 (print "== maps ==")
 (nl)
